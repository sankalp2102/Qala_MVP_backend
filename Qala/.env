# ─────────────────────────────────────────────────────────────────────────────
# DJANGO CORE
# ─────────────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=django-insecure-qala-local-dev-key-change-this-before-production-2024
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE — SQLite for local (no config needed, just leave these blank)
# These are only read in production.py so safe to leave as-is locally
# ─────────────────────────────────────────────────────────────────────────────
DB_NAME=qala_db
DB_USER=qala_user
DB_PASSWORD=QalaMain2024
DB_HOST=django_db
DB_PORT=5432

# ─────────────────────────────────────────────────────────────────────────────
# SUPERTOKENS — points to your GCP VM
# Replace YOUR_GCP_VM_EXTERNAL_IP with the actual external IP of your VM
# Example: 34.100.200.50
# ─────────────────────────────────────────────────────────────────────────────
SUPERTOKENS_URL=http://YOUR_GCP_VM_EXTERNAL_IP:3567
SUPERTOKENS_API_KEY=70031101955ba2c956c9f6dd5469fa65a85bc91d
SUPERTOKENS_APP_NAME=Qala
SUPERTOKENS_API_DOMAIN=http://localhost:8000
SUPERTOKENS_WEBSITE_DOMAIN=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# INTERNAL HOOK SECRET
# This protects the /api/auth/customer-hook/ endpoint
# Any random string works for local — keep it consistent
# ─────────────────────────────────────────────────────────────────────────────
SUPERTOKENS_HOOK_SECRET=local-hook-secret-qala-dev-2024

# ─────────────────────────────────────────────────────────────────────────────
# CORS — allowed frontend origins
# ─────────────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─────────────────────────────────────────────────────────────────────────────
# MEDIA FILES
# ─────────────────────────────────────────────────────────────────────────────
MEDIA_URL=/media/
MEDIA_ROOT=media